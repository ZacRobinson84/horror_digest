---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const digests = await getCollection('digests');
const sorted = digests.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = sorted[0];
const { Content } = await render(latest);
const dateStr = latest.data.date.toISOString().slice(0, 10);
const fileId = dateStr.replace(/-/g, '.').slice(2);
---
<Layout title={`Horror Digest — ${dateStr}`}>
  <div class="file-card">
    <span class="field"><span class="label">File №:</span><span class="value accent">{fileId}</span></span>
    <span class="field"><span class="label">Transmissions:</span><span class="value">{latest.data.itemCount} / {latest.data.articleCount}</span></span>
    <span class="field"><span class="label">Sources:</span><span class="value">{latest.data.sourceCount}</span></span>
    <span class="field"><span class="label">Classification:</span><span class="value">Active</span></span>
  </div>
  <article>
    <Content />
  </article>
  <footer class="dispatch-footer">
    <span class="sigil"><span class="glyph">∎</span>End File<span class="glyph">∎</span></span>
    <a href="/archive/" class="to-archive">Open Archive →</a>
  </footer>
</Layout>
